{
  "schemaVersion": 2,
  "manifest": {
    "name": "nanoSID",
    "version": "0.9.2",
    "type": "instrument",
    "author": "the-bimbly1",
    "description": "6581 SID with combined waveforms"
  },
  "parameters": [
    { "key": "waveform", "label": "WAVE", "min": 0, "max": 7, "default": 1, "step": 1, "options": ["Triangle", "Saw", "Pulse", "Noise", "Tri+Saw", "Tri+Pulse", "Saw+Pulse", "All"] },
    { "key": "pulsewidth", "label": "PW", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
    { "key": "attack", "label": "ATT", "min": 0.001, "max": 2, "default": 0.01, "step": 0.001 },
    { "key": "decay", "label": "DEC", "min": 0.001, "max": 3, "default": 0.3, "step": 0.001 },
    { "key": "sustain", "label": "SUS", "min": 0, "max": 1, "default": 0.7, "step": 0.01 },
    { "key": "release", "label": "REL", "min": 0.001, "max": 4, "default": 0.1, "step": 0.001 },
    { "key": "cutoff", "label": "CUT", "min": 100, "max": 12000, "default": 3000, "step": 1 },
    { "key": "resonance", "label": "RES", "min": 0, "max": 0.95, "default": 0.4, "step": 0.01 },
    { "key": "dis", "label": "DIS", "min": 0, "max": 10, "default": 5, "step": 0.1 },
    { "key": "crn", "label": "CRN", "min": 0, "max": 10, "default": 5, "step": 0.1 }
  ],
  "dsp": {
    "processorName": "nanosid-processor",
    "voices": 1
  },
  "ui": {
    "layout": "flex",
    "accentColor": "#00ffcc",
    "controls": [
      { "type": "knob", "parameter": "waveform", "label": "WAVE" },
      { "type": "knob", "parameter": "pulsewidth", "label": "PW" },
      { "type": "knob", "parameter": "attack", "label": "ATT" },
      { "type": "knob", "parameter": "decay", "label": "DEC" },
      { "type": "knob", "parameter": "sustain", "label": "SUS" },
      { "type": "knob", "parameter": "release", "label": "REL" },
      { "type": "knob", "parameter": "cutoff", "label": "CUT" },
      { "type": "knob", "parameter": "resonance", "label": "RES" },
      { "type": "knob", "parameter": "dis", "label": "DIS" },
      { "type": "knob", "parameter": "crn", "label": "CRN" }
    ]
  }
}